    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/localize": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@handsontable/angular-wrapper": "^17.0.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@tinymce/tinymce-angular": "^9.1.1",
    "d3": "^7.8.5",
    "handsontable": "^17.0.0",
    "moment-timezone": "^0.6.0",
    "ng-dynamic-component": "^10.8.2",
    "ng-in-viewport": "^16.1.0",
    "ngx-captcha": "^14.0.0",
    "ngx-page-scroll-core": "^16.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "ua-parser-js": "^1.0.41",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@eslint/js": "^10.0.1",
    "@types/d3": "^7.4.3",
    "@types/ua-parser-js": "^0.7.39",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jest-preset-angular": "^16.1.5",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
