               UTC 
            </div>
          </div>
          <div
            class="row text-center"
          >
            <div
              class="col-md-2 text-md-end font-bold"
            >
              Course Name
            </div>
            <div
              class="col-md-10 text-md-start"
              id="course-name"
            >
               Example Course 
            </div>
          </div>
