        >
          Select all students
        </label>
      </div>
      <div
        class="form-check"
      >
        <input
          class="form-check-input ng-untouched ng-pristine ng-valid"
          id="remindNotSubmittedStu"
          type="checkbox"
        />
        <label
          class="form-check-label"
          for="remindNotSubmittedStu"
        >
          Select all students not yet submitted
        </label>
      </div>
      <div
        class="form-check"
      >
        <input
          class="form-check-input ng-untouched ng-pristine ng-valid"
