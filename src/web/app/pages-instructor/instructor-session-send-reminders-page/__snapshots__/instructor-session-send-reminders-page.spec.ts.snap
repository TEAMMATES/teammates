// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`InstructorSessionSendRemindersPageComponent > should snap when there are no participants to remind 1`] = `
<tm-instructor-session-send-reminders-page
  courseId={[Function String]}
  courseName={[Function String]}
  courseService={[Function _CourseService]}
  feedbackSessionEndingTimestamp={[Function Number]}
  feedbackSessionId={[Function String]}
  feedbackSessionName={[Function String]}
  feedbackSessionTimeZone={[Function String]}
  feedbackSessionsService={[Function _FeedbackSessionsService]}
  hasLoadingFailed="false"
  instructorListInfoTableRowModels={[Function Array]}
  instructorService={[Function _InstructorService]}
  isLoading="false"
  isSendingCopyToInstructor={[Function Boolean]}
  isSendingReminders="false"
  navigationService={[Function _NavigationService]}
  preselectNonSubmitters="false"
  route={[Function Object]}
  statusMessageService={[Function _StatusMessageService]}
  studentListInfoTableRowModels={[Function Array]}
  studentService={[Function _StudentService]}
>
  <tm-loading-retry>
    <div
      aria-hidden="true"
    />
    <div>
      <div
        class="card bg-light top-padded text-center text-sm-start"
      >
        <div
          class="card-body"
        >
          <div
            class="row text-center"
          >
            <div
              class="col-md-2 text-md-end font-bold"
            >
              Course ID
            </div>
            <div
              class="col-md-3 text-md-start"
              id="course-id"
            >
               exampleId 
            </div>
          </div>
          <div
            class="row text-center"
          >
            <div
              class="col-md-2 text-md-end font-bold"
            >
              Time Zone
            </div>
            <div
              class="col-md-3 text-md-start"
              id="time-zone"
            >
               UTC 
            </div>
          </div>
          <div
            class="row text-center"
          >
            <div
              class="col-md-2 text-md-end font-bold"
            >
              Course Name
            </div>
            <div
              class="col-md-10 text-md-start"
              id="course-name"
            >
               Example Course 
            </div>
          </div>
          <div
            class="row text-center"
          >
            <div
              class="col-md-2 text-md-end font-bold"
            >
              Session Name
            </div>
            <div
              class="col-md-10 text-md-start"
              id="session-name"
            >
               Test Session 
            </div>
          </div>
          <div
            class="row text-center"
          >
            <div
              class="col-md-2 text-md-end font-bold"
            >
              Deadline
            </div>
            <div
              class="col-md-10 text-md-start"
              id="deadline"
            >
               5 Apr 2000 2:00:00 
            </div>
          </div>
        </div>
      </div>
      <p>
         Select the student(s) or instructor(s) you want to remind, then click 
        <b>
          Send Reminders
        </b>
         at the bottom of the page. 
      </p>
      <h4
        class="p-2 bg-info"
      >
        There are no participants to remind.
      </h4>
    </div>
  </tm-loading-retry><br /><div
    class="align-row-right"
  >
    <span
      class="form-check align-self-center"
    >
      <input
        class="form-check-input ng-untouched ng-pristine ng-valid"
        id="sendCopyToIns"
        type="checkbox"
      />
      <label
        class="form-check-label"
        for="sendCopyToIns"
      >
        Send me a copy
      </label>
    </span>
    <button
      class="btn btn-light"
      id="cancel-btn"
      type="button"
    >
      Cancel
    </button>
    <button
      class="btn btn-primary"
      disabled=""
      id="send-reminders-btn"
      type="button"
    >
       Send Reminders 
    </button>
  </div>
</tm-instructor-session-send-reminders-page>
`;

exports[`InstructorSessionSendRemindersPageComponent > should snap while loading 1`] = `
<tm-instructor-session-send-reminders-page
  courseId=""
  courseName=""
  courseService={[Function _CourseService]}
  feedbackSessionEndingTimestamp="0"
  feedbackSessionId={[Function String]}
  feedbackSessionName=""
  feedbackSessionTimeZone={[Function String]}
  feedbackSessionsService={[Function _FeedbackSessionsService]}
  hasLoadingFailed="false"
  instructorListInfoTableRowModels={[Function Array]}
  instructorService={[Function _InstructorService]}
  isLoading={[Function Boolean]}
  isSendingCopyToInstructor={[Function Boolean]}
  isSendingReminders="false"
  navigationService={[Function _NavigationService]}
  preselectNonSubmitters="false"
  route={[Function Object]}
  statusMessageService={[Function _StatusMessageService]}
  studentListInfoTableRowModels={[Function Array]}
  studentService={[Function _StudentService]}
>
  <tm-loading-retry>
    <div
      aria-hidden="true"
    />
    <tm-loading-spinner>
      <div
        class="loading-container"
      >
        <div
          class="row spinner-border text-primary"
          role="status"
        />
        <div
          class="row text-secondary"
        >
          Loading...
        </div>
      </div>
    </tm-loading-spinner>
  </tm-loading-retry><br /><div
    class="align-row-right"
  >
    <span
      class="form-check align-self-center"
    >
      <input
        class="form-check-input ng-untouched ng-pristine ng-valid"
        id="sendCopyToIns"
        type="checkbox"
      />
      <label
        class="form-check-label"
        for="sendCopyToIns"
      >
        Send me a copy
      </label>
    </span>
    <button
      class="btn btn-light"
      id="cancel-btn"
      type="button"
    >
      Cancel
    </button>
    <button
      class="btn btn-primary"
      disabled=""
      id="send-reminders-btn"
      type="button"
    >
       Send Reminders 
    </button>
  </div>
</tm-instructor-session-send-reminders-page>
`;

exports[`InstructorSessionSendRemindersPageComponent > should snap with students and instructors loaded 1`] = `
