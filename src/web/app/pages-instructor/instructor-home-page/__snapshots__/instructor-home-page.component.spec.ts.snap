exports[`InstructorHomePageComponent > should snap with one course with error loading feedback sessions 1`] = `
<tm-instructor-home-page
  SessionsTableColumn={[Function Object]}
  SortBy={[Function Object]}
  SortableTableHeaderColorScheme={[Function Object]}
  allCoursesList={[Function Array]}
  copyProgressPercentage="0"
  courseService={[Function _CourseService]}
  courseTabModels={[Function Array]}
  coursesOfModifiedSession={[Function Array]}
  failedToCopySessions={[Function Object]}
  feedbackQuestionsService={[Function _FeedbackQuestionsService]}
  feedbackSessionActionsService={[Function _FeedbackSessionActionsService]}
  feedbackSessionsService={[Function _FeedbackSessionsService]}
  hasCoursesLoaded={[Function Boolean]}
  hasCoursesLoadingFailed="false"
  initialSortBy={[Function Number]}
  instructorCoursesSortBy={[Function Number]}
  instructorService={[Function _InstructorService]}
  isCopyLoading="false"
  isCopyingCourse="false"
  isNewUser="false"
  isResultActionLoading="false"
  isSendReminderLoading="false"
  modifiedSession={[Function Object]}
  modifiedTimestampsModal={[Function TemplateRef]}
  navigationService={[Function _NavigationService]}
  ngbModal={[Function NgbModal]}
  numberOfSessionsCopied="0"
  progressBarService={[Function _ProgressBarService]}
  publishStatusName={[Function _PublishStatusNamePipe]}
  publishUnpublishRetryAttempts="undefined"
  sessionEditFormModel={[Function Object]}
  simpleModalService={[Function _SimpleModalService]}
  sortOrder="0"
  statusMessageService={[Function _StatusMessageService]}
  studentService={[Function _StudentService]}
  tableComparatorService={[Function _TableComparatorService]}
  timezoneService={[Function _TimezoneService]}
  totalNumberOfSessionsToCopy="0"
>
  <h1>
    Home
  </h1><div
    class="row mb-3"
  >
    <div
      class="col-4 mt-auto"
    >
      <a
        class="btn btn-success"
        href="/web/instructor/courses?isAddNewCourse=true"
        tmrouterlink="/web/instructor/courses"
      >
        <i
          class="fas fa-plus"
        />
         Add New Course 
      </a>
    </div>
    <div
      class="col-8"
    >
      <div
        class="float-end"
      >
        <strong
          class="d-inline"
        >
           Sort By: 
        </strong>
        <div
          class="btn-group"
          data-toggle="buttons"
        >
          <button
            class="btn btn-light"
            id="sort-course-id"
          >
             Course ID 
          </button>
          <button
            class="btn btn-light"
            id="sort-course-name"
          >
             Course Name 
          </button>
          <button
            class="btn btn-light"
            disabled=""
            id="sort-course-date"
          >
             Creation Date 
          </button>
        </div>
      </div>
    </div>
  </div><tm-loading-retry>
    <div
      aria-hidden="true"
    />
    <div>
      <div>
        <div
          class="card"
          id="course-tab-0"
        >
          <div
            class="card-header bg-primary text-white cursor-pointer"
          >
            <b
              class="course-details text-break"
            >
              [CS3281]: Thematic Systems I
            </b>
          </div>
          <div
            class="card-body padding-0 table-responsive collapse show"
          >
            <tm-loading-retry>
              <div
                aria-hidden="true"
              />
              <tm-loading-spinner>
                <div
                  class="loading-container"
                >
                  <div
                    class="row spinner-border text-primary"
                    role="status"
                  />
                  <div
                    class="row text-secondary"
                  >
                    Loading...
                  </div>
                </div>
              </tm-loading-spinner>
            </tm-loading-retry>
          </div>
        </div>
      </div>
    </div>
  </tm-loading-retry>
</tm-instructor-home-page>
`;

