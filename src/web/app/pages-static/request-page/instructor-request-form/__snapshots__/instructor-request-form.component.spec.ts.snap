// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`InstructorRequestFormComponent > should render correctly 1`] = `
<tm-instructor-request-form
  EMAIL_MAX_LENGTH={[Function Number]}
  INSTITUTION_NAME_MAX_LENGTH={[Function Number]}
  PERSON_NAME_MAX_LENGTH={[Function Number]}
  accountService={[Function Object]}
  arf={[Function FormGroup]}
  comments={[Function FormControl]}
  country={[Function FormControl]}
  countryOptions={[Function Array]}
  countryService={[Function _CountryService]}
  email={[Function FormControl]}
  hasSubmitAttempt="false"
  institution={[Function FormControl]}
  isLoading="false"
  name={[Function FormControl]}
  requestSubmissionEvent={[Function EventEmitter_]}
  serverErrorMessage=""
>
  <form
    class="ng-untouched ng-pristine ng-invalid"
    novalidate=""
  >
    <div
      class="form-group required"
    >
      <label
        class="qn"
        for="name"
        id="name-label"
      >
         Full Name 
      </label>
      <p
        class="help-block"
      >
         This is the name that will be shown to your students. You may include salutation (Dr. Prof. etc.) 
      </p>
      <input
        aria-invalid="true"
        autocomplete="name"
        class="form-control ng-untouched ng-pristine ng-invalid"
        id="name"
        required=""
        type="text"
      />
      <div
        aria-describedby="name-label"
        class="invalid-feedback"
        role="alert"
      >
        Please enter your name.
      </div>
    </div>
    <br />
    <div
      class="form-group required"
    >
      <label
        class="qn"
        for="institution"
        id="institution-label"
      >
         University / Institution 
      </label>
      <p
        class="help-block"
      >
        Please give full name of the university/institution.
      </p>
      <input
        aria-invalid="true"
        autocomplete="organization"
        class="form-control ng-untouched ng-pristine ng-invalid"
        id="institution"
        required=""
        type="text"
      />
      <div
        aria-describedby="institution-label"
        class="invalid-feedback"
        role="alert"
      >
         Please enter your institution name. 
      </div>
    </div>
    <br />
    <div
      class="form-group required"
    >
      <label
        class="qn"
        for="country"
        id="country-label"
      >
         Country or Region 
      </label>
      <p
        class="help-block"
      >
        The country or region where your university/institution is based.
      </p>
      <tm-searchable-combobox
        class="ng-untouched ng-pristine ng-invalid"
        inputid="country"
        placeholder="Search for a country or region..."
      >
        <div
          class="searchable-combobox position-relative w-100"
          data-expanded="false"
          filtermode="manual"
          ngcombobox=""
        >
          <input
            aria-autocomplete="list"
            aria-disabled="false"
            aria-expanded="false"
            autocomplete="off"
            class="form-control w-100 searchable-combobox-input"
            id="country"
            ngcomboboxinput=""
            placeholder="Search for a country or region..."
            role="combobox"
            type="text"
          />
          <button
            aria-label="Open"
            class="searchable-combobox-toggle"
            tabindex="-1"
            type="button"
          >
            <span
              aria-hidden="true"
              class="fa fa-chevron-down"
            />
          </button>
        </div>
      </tm-searchable-combobox>
    </div>
    <br />
    <div
      class="form-group required"
    >
      <label
        class="qn"
        for="email"
        id="email-label"
      >
         Official email address 
      </label>
      <p
        class="help-block"
      >
         The email address 
        <b>
          given to you by your school/university
        </b>
        . This email address will be visible to students you enroll in TEAMMATES. 
      </p>
      <input
        aria-invalid="true"
        autocomplete="email"
        class="form-control ng-untouched ng-pristine ng-invalid"
        id="email"
        required=""
        type="email"
      />
      <div
        aria-describedby="email-label"
        class="invalid-feedback"
        role="alert"
      >
        Please enter your email address.
      </div>
    </div>
    <br />
    <div
      class="form-group"
    >
      <label
        class="qn"
        for="comments"
        id="comments-label"
      >
         Any other comments/queries 
      </label>
      <textarea
        aria-invalid="false"
        class="form-control ng-untouched ng-pristine ng-valid"
        id="comments"
      />
    </div>
    <br />
    <button
      aria-label="Submit form"
      class="btn btn-primary"
      id="submit-button"
      type="submit"
    >
       Submit 
    </button>
  </form>
</tm-instructor-request-form>
`;
