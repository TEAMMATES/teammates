// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`RequestPageComponent > should render correctly after form is submitted 1`] = `
<tm-request-page
  authInfo={[Function Function]}
  authService={[Function _AuthService]}
  backendUrl={[Function String]}
  isLoading={[Function Function]}
  loginUrl={[Function Function]}
  submittedFormData={[Function Function]}
>
  <div
    class="row"
  >
    <div
      class="col-12 col-lg-8"
    >
      <h1
        class="color-orange"
      >
        Create Courses with TEAMMATES
      </h1>
      <div>
        <div>
          <p>
            Your request has been submitted successfully.
          </p>
          <table
            class="table table-bordered my-3"
          >
            <tbody>
              <tr>
                <th
                  class="col-3"
                  scope="row"
                >
                  Full Name
                </th>
                <td>
                  Jane Smith
                </td>
              </tr>
              <tr>
                <th
                  scope="row"
                >
                  Institution
                </th>
                <td>
                  University of Example
                </td>
              </tr>
              <tr>
                <th
                  scope="row"
                >
                  Country or Region
                </th>
                <td>
                  Example Republic
                </td>
              </tr>
              <tr>
                <th
                  scope="row"
                >
                  Email
                </th>
                <td>
                  js@exampleu.edu
                </td>
              </tr>
              <tr>
                <th
                  scope="row"
                >
                  Comments
                </th>
                <td>
                  <span
                    class="empty-field-placeholder"
                  />
                </td>
              </tr>
            </tbody>
          </table>
          <p>
             An acknowledgement email has been sent to 
            <strong>
              js@exampleu.edu
            </strong>
            . We will process your request and notify you once course creation access has been granted. 
          </p>
        </div>
      </div>
    </div>
  </div>
</tm-request-page>
`;

exports[`RequestPageComponent > should render correctly before submission 1`] = `
<tm-request-page
  authInfo={[Function Function]}
  authService={[Function _AuthService]}
  backendUrl={[Function String]}
  isLoading={[Function Function]}
  loginUrl={[Function Function]}
  submittedFormData={[Function Function]}
>
  <div
    class="row"
  >
    <div
      class="col-12 col-lg-8"
    >
      <h1
        class="color-orange"
      >
        Create Courses with TEAMMATES
      </h1>
      <div>
        <div>
          <p>
             To create courses, we first need to verify your affiliation with the institution you represent. Once verified, you'll be able to create courses in TEAMMATES. 
          </p>
          <p>
            Students and instructors who have been added to existing courses do not need to submit this form.
          </p>
        </div>
        <hr />
        <div
          class="alert alert-success"
          role="alert"
        >
           Signed in as: 
          <strong>
            test@example.com
          </strong>
        </div>
        <tm-instructor-request-form>
          <form
            class="ng-untouched ng-pristine ng-invalid"
            novalidate=""
          >
            <div
              class="form-group required"
            >
              <label
                class="qn"
                for="name"
                id="name-label"
              >
                 Full Name 
              </label>
              <p
                class="help-block"
              >
                 This is the name that will be shown to your students. You may include salutation (Dr. Prof. etc.) 
              </p>
              <input
                aria-invalid="true"
                autocomplete="name"
                class="form-control ng-untouched ng-pristine ng-invalid"
                id="name"
                required=""
                type="text"
              />
              <div
                aria-describedby="name-label"
                class="invalid-feedback"
                role="alert"
              >
                Please enter your name.
              </div>
            </div>
            <br />
            <div
              class="form-group required"
            >
              <label
                class="qn"
                for="institution"
                id="institution-label"
              >
                 University / Institution 
              </label>
              <p
                class="help-block"
              >
                Please give full name of the university/institution.
              </p>
              <input
                aria-invalid="true"
                autocomplete="organization"
                class="form-control ng-untouched ng-pristine ng-invalid"
                id="institution"
                required=""
                type="text"
              />
              <div
                aria-describedby="institution-label"
                class="invalid-feedback"
                role="alert"
              >
                 Please enter your institution name. 
              </div>
            </div>
            <br />
            <div
              class="form-group required"
            >
              <label
                class="qn"
                for="country"
                id="country-label"
              >
                 Country or Region 
              </label>
              <p
                class="help-block"
              >
                The country or region where your university/institution is based.
              </p>
              <tm-searchable-combobox
                class="ng-untouched ng-pristine ng-invalid"
                inputid="country"
                placeholder="Search for a country or region..."
              >
                <div
                  class="searchable-combobox position-relative w-100"
                  data-expanded="false"
                  filtermode="manual"
                  ngcombobox=""
                >
                  <input
                    aria-autocomplete="list"
                    aria-disabled="false"
                    aria-expanded="false"
                    autocomplete="off"
                    class="form-control w-100 searchable-combobox-input"
                    id="country"
                    ngcomboboxinput=""
                    placeholder="Search for a country or region..."
                    role="combobox"
                    type="text"
                  />
                  <button
                    aria-label="Open"
                    class="searchable-combobox-toggle"
                    tabindex="-1"
                    type="button"
                  >
                    <span
                      aria-hidden="true"
                      class="fa fa-chevron-down"
                    />
                  </button>
                </div>
              </tm-searchable-combobox>
            </div>
            <br />
            <div
              class="form-group required"
            >
              <label
                class="qn"
                for="email"
                id="email-label"
              >
                 Official email address 
              </label>
              <p
                class="help-block"
              >
                 The email address 
                <b>
                  given to you by your school/university
                </b>
                . This email address will be visible to students you enroll in TEAMMATES. 
              </p>
              <input
                aria-invalid="true"
                autocomplete="email"
                class="form-control ng-untouched ng-pristine ng-invalid"
                id="email"
                required=""
                type="email"
              />
              <div
                aria-describedby="email-label"
                class="invalid-feedback"
                role="alert"
              >
                Please enter your email address.
              </div>
            </div>
            <br />
            <div
              class="form-group"
            >
              <label
                class="qn"
                for="comments"
                id="comments-label"
              >
                 Any other comments/queries 
              </label>
              <textarea
                aria-invalid="false"
                class="form-control ng-untouched ng-pristine ng-valid"
                id="comments"
              />
            </div>
            <br />
            <button
              aria-label="Submit form"
              class="btn btn-primary"
              id="submit-button"
              type="submit"
            >
               Submit 
            </button>
          </form>
        </tm-instructor-request-form>
        <hr />
      </div>
    </div>
  </div>
</tm-request-page>
`;

exports[`RequestPageComponent > should render correctly when not signed in 1`] = `
<tm-request-page
  authInfo={[Function Function]}
  authService={[Function _AuthService]}
  backendUrl={[Function String]}
  isLoading={[Function Function]}
  loginUrl={[Function Function]}
  submittedFormData={[Function Function]}
>
  <div
    class="row"
  >
    <div
      class="col-12 col-lg-8"
    >
      <h1
        class="color-orange"
      >
        Create Courses with TEAMMATES
      </h1>
      <div>
        <div>
          <p>
             To create courses, we first need to verify your affiliation with the institution you represent. Once verified, you'll be able to create courses in TEAMMATES. 
          </p>
          <p>
            Students and instructors who have been added to existing courses do not need to submit this form.
          </p>
        </div>
        <hr />
        <div
          class="alert alert-warning d-flex align-items-center justify-content-between"
          role="alert"
        >
          <span>
            You must be signed in to submit this form.
          </span>
          <a
            class="btn btn-warning"
            href="http://localhost:8080/login"
          >
            Sign in
          </a>
        </div>
      </div>
    </div>
  </div>
</tm-request-page>
`;
