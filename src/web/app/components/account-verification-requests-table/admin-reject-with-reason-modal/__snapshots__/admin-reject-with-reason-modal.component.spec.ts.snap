// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`RejectWithReasonModal > should show empty title and body 1`] = `
<tm-reject-with-reason-modal
  accountVerificationRequestEmail=""
  accountVerificationRequestName=""
  activeModal={[Function NgbActiveModal]}
  existingAccount={[Function Object]}
  rejectionReasonBody={[Function String]}
  rejectionReasonTitle={[Function String]}
  statusMessageService={[Function _StatusMessageService]}
>
  <div
    class="modal-header bg-warning"
  >
    <h5
      class="modal-title"
    >
      <div>
        Reject Account Verification Request for  With Reason
      </div>
    </h5>
    <button
      aria-label="Close"
      class="btn-close"
      type="button"
    />
  </div><div
    class="modal-body"
    id="reject-account-verification-request-modal"
  >
    <div
      class="row"
    >
      <div
        class="col-12"
      >
        <div>
          <label>
            <b>
              Rejection Message Title:
            </b>
          </label>
        </div>
        <div
          class="form-group"
        >
          <input
            class="form-control"
            id="rejection-reason-title"
            type="text"
          />
        </div>
        <div>
          <label>
            <b>
              Rejection Message Body:
            </b>
          </label>
        </div>
        <tm-rich-text-editor
          id="rejection-reason-body"
        >
          <div>
            <editor
              class="editor ng-untouched ng-pristine ng-valid"
              placeholder=""
            >
              <textarea
                id="tinymce-editor-id-1"
                style="visibility: hidden;"
              />
            </editor>
          </div>
        </tm-rich-text-editor>
      </div>
      <div
        class="modal-footer"
      >
        <button
          class="btn btn-light"
          id="btn-cancel-reject-request"
          type="button"
        >
           Cancel 
        </button>
        <button
          class="btn btn-warning"
          id="btn-confirm-reject-request"
          type="button"
        >
          Reject
        </button>
      </div>
    </div>
  </div>
</tm-reject-with-reason-modal>
`;
