exports[`AdminAccountVerificationRequestsPageComponent > should snap with default view 1`] = `
<tm-admin-account-verification-requests-page
  accountReqs={[Function Function]}
  accountService={[Function _AccountService]}
  committedSearch={[Function Function]}
  dateFormatService={[Function _DateFormatService]}
  searchQuery={[Function Function]}
  statusMessageService={[Function _StatusMessageService]}
  timezoneService={[Function _TimezoneService]}
>
  <div
    class="card bg-light top-padded"
  >
    <div
      class="card-body"
    >
      <div
        class="input-group"
      >
        <input
          aria-label="Search account verification requests"
          class="form-control ng-untouched ng-pristine ng-valid"
          id="search-box"
          placeholder="Search by name, email, or institute..."
          type="text"
        />
        <button
          class="btn btn-primary"
          id="search-button"
        >
          Search
        </button>
      </div>
    </div>
  </div><div
    class="card bg-light top-padded"
  >
    <div
      class="card-header bg-primary text-white"
    >
      <strong>
        Account Verification Requests
      </strong>
    </div>
    <tm-account-verification-request-table>
      <table
        class="table table-striped"
        id="search-table-account-verification-request"
        style="table-layout: fixed;"
      >
        <thead>
          <tr>
            <th
              class="text-nowrap"
            >
              Name
            </th>
            <th
              class="text-nowrap"
            >
              Email
            </th>
            <th
              class="text-nowrap"
            >
              Status
            </th>
            <th
              class="text-nowrap"
            >
              Institute, Country
            </th>
            <th
              class="text-nowrap"
            >
              Submitted At
            </th>
            <th
              class="text-nowrap"
            >
              Comments
            </th>
            <th
              class="text-nowrap"
            >
              Options
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td
              class="text-center"
              colspan="7"
            >
              No pending account verification requests
            </td>
          </tr>
        </tbody>
      </table>
    </tm-account-verification-request-table>
  </div>
</tm-admin-account-verification-requests-page>
`;
