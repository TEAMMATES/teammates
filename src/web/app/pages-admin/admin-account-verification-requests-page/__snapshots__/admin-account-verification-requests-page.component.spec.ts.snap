// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AdminAccountVerificationRequestsPageComponent > should snap with default view 1`] = `
<tm-admin-account-verification-requests-page
  accountReqs={[Function Function]}
  accountService={[Function _AccountService]}
  allAccountReqs={[Function Function]}
  committedSearch={[Function Function]}
  currentPage={[Function Function]}
  dateFormatService={[Function _DateFormatService]}
  pageSize={[Function Number]}
  pages={[Function Function]}
  searchQuery={[Function Function]}
  statusMessageService={[Function _StatusMessageService]}
  timezoneService={[Function _TimezoneService]}
  totalPages={[Function Function]}
>
  <div
    class="card bg-light top-padded"
  >
    <div
      class="card-body"
    >
      <div
        class="input-group"
      >
        <input
          aria-label="Search account verification requests"
          class="form-control ng-untouched ng-pristine ng-valid"
          id="search-box"
          placeholder="Search by name, email, or institute..."
          type="text"
        />
        <button
          class="btn btn-primary"
          id="search-button"
        >
          Search
        </button>
      </div>
    </div>
  </div><div
    class="card bg-light top-padded"
  >
    <tm-account-verification-request-table>
      <table
        class="table table-striped"
        id="search-table-account-verification-request"
        style="table-layout: fixed;"
      >
        <thead>
          <tr>
            <th
              class="text-nowrap"
            >
              Name
            </th>
            <th
              class="text-nowrap"
            >
              Email
            </th>
            <th
              class="text-nowrap"
            >
              Status
            </th>
            <th
              class="text-nowrap"
            >
              Institute, Country
            </th>
            <th
              class="text-nowrap"
            >
              Submitted At
            </th>
            <th
              class="text-nowrap"
            >
              Comments
            </th>
            <th
              class="text-nowrap"
            >
              Options
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td
              class="text-center"
              colspan="7"
            >
              No pending account verification requests
            </td>
          </tr>
        </tbody>
      </table>
    </tm-account-verification-request-table>
    <div
      class="card-footer d-flex justify-content-center"
    >
      <nav
        aria-label="Account verification requests pagination"
      >
        <ul
          class="pagination mb-0"
        >
          <li
            class="page-item disabled"
          >
            <button
              aria-label="Previous"
              class="page-link"
            >
              <span
                aria-hidden="true"
              >
                «
              </span>
            </button>
          </li>
          <li
            class="page-item active"
          >
            <button
              class="page-link"
            >
              1
            </button>
          </li>
          <li
            class="page-item disabled"
          >
            <button
              aria-label="Next"
              class="page-link"
            >
              <span
                aria-hidden="true"
              >
                »
              </span>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</tm-admin-account-verification-requests-page>
`;
