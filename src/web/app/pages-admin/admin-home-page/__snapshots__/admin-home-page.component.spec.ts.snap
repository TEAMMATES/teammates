// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AdminHomePageComponent > should snap with default view 1`] = `
<tm-admin-home-page
  accountReqs={[Function Array]}
  accountService={[Function _AccountService]}
  dateFormatService={[Function _DateFormatService]}
  statusMessageService={[Function _StatusMessageService]}
  timezoneService={[Function _TimezoneService]}
>
  <div
    class="card bg-light top-padded"
  >
    <div
      class="card-header bg-primary text-white d-flex justify-content-between align-items-center"
    >
      <strong>
        Pending Account Verification Requests
      </strong>
      <a
        class="btn btn-light btn-sm"
        href="/web/admin/account-verification-requests"
        tmrouterlink="/web/admin/account-verification-requests"
      >
        View All
      </a>
    </div>
    <tm-account-verification-request-table>
      <table
        class="table table-striped"
        id="search-table-account-verification-request"
        style="table-layout: fixed;"
      >
        <thead>
          <tr>
            <th
              class="text-nowrap"
            >
              Name
            </th>
            <th
              class="text-nowrap"
            >
              Email
            </th>
            <th
              class="text-nowrap"
            >
              Status
            </th>
            <th
              class="text-nowrap"
            >
              Institute, Country
            </th>
            <th
              class="text-nowrap"
            >
              Submitted At
            </th>
            <th
              class="text-nowrap"
            >
              Comments
            </th>
            <th
              class="text-nowrap"
            >
              Options
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td
              class="text-center"
              colspan="7"
            >
              No account verification requests found.
            </td>
          </tr>
        </tbody>
      </table>
    </tm-account-verification-request-table>
  </div>
</tm-admin-home-page>
`;
