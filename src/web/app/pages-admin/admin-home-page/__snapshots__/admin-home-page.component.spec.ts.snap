// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AdminHomePageComponent > should snap with default view 1`] = `
<tm-admin-home-page
  accountReqs={[Function Array]}
  accountService={[Function _AccountService]}
  countryOptions={[Function Array]}
  countryService={[Function _CountryService]}
  dateFormatService={[Function _DateFormatService]}
  instructorCountry=""
  instructorEmail=""
  instructorInstitution=""
  instructorName=""
  isAddingSingleInstructor="false"
  statusMessageService={[Function _StatusMessageService]}
  timezoneService={[Function _TimezoneService]}
>
  <div
    class="card bg-light top-padded"
  >
    <div
      class="card-body"
    >
      <div>
        <label
          for="instructor-name"
        >
          <strong>
            Name:
          </strong>
        </label>
        <input
          class="form-control ng-untouched ng-pristine ng-valid"
          id="instructor-name"
          type="text"
        />
      </div>
      <div
        class="top-padded"
      >
        <label
          for="instructor-email"
        >
          <strong>
            Email:
          </strong>
        </label>
        <input
          class="form-control ng-untouched ng-pristine ng-valid"
          id="instructor-email"
          type="text"
        />
      </div>
      <div
        class="top-padded"
      >
        <label
          for="instructor-institution"
        >
          <strong>
            Institution:
          </strong>
        </label>
        <input
          class="form-control ng-untouched ng-pristine ng-valid"
          id="instructor-institution"
          type="text"
        />
      </div>
      <div
        class="top-padded"
      >
        <label
          for="instructor-country"
        >
          <strong>
            Country or Region:
          </strong>
        </label>
        <tm-searchable-combobox
          class="ng-untouched ng-pristine ng-valid"
          inputid="instructor-country"
          placeholder="Search for a country or region..."
        >
          <div
            class="searchable-combobox position-relative w-100"
            data-expanded="false"
            filtermode="manual"
            ngcombobox=""
          >
            <input
              aria-autocomplete="list"
              aria-disabled="false"
              aria-expanded="false"
              autocomplete="off"
              class="form-control w-100 searchable-combobox-input"
              id="instructor-country"
              ngcomboboxinput=""
              placeholder="Search for a country or region..."
              role="combobox"
              type="text"
            />
            <button
              aria-label="Open"
              class="searchable-combobox-toggle"
              tabindex="-1"
              type="button"
            >
              <span
                aria-hidden="true"
                class="fa fa-chevron-down"
              />
            </button>
          </div>
        </tm-searchable-combobox>
      </div>
      <div
        class="top-padded"
      >
        <button
          class="btn btn-primary"
          id="add-instructor"
        >
           Add Instructor 
        </button>
      </div>
    </div>
  </div><tm-account-request-table>
    <div
      class="card bg-light top-padded"
    >
      <div
        class="card-header bg-primary text-white"
      >
        <strong>
          Pending Account Requests
        </strong>
      </div>
      <div
        class="table-responsive"
      >
        <table
          class="table table-striped data-table"
          id="search-table-account-request"
        >
          <thead>
            <tr>
              <th>
                Name
              </th>
              <th>
                Email
              </th>
              <th>
                Status
              </th>
              <th>
                Institute
              </th>
              <th>
                Country
              </th>
              <th>
                Created At
              </th>
              <th>
                Comments
              </th>
              <th>
                Options
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td
                class="text-center"
                colspan="8"
              >
                No pending account requests
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </tm-account-request-table>
</tm-admin-home-page>
`;
