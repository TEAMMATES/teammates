// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AdminHomePageComponent > should snap with default view 1`] = `
<tm-admin-home-page
  accountReqs={[Function Array]}
  accountService={[Function _AccountService]}
  dateFormatService={[Function _DateFormatService]}
  statusMessageService={[Function _StatusMessageService]}
  timezoneService={[Function _TimezoneService]}
>
  <div
    class="card bg-light top-padded"
  >
    <div
      class="card-header bg-primary text-white"
    >
      <strong>
        Pending Account Verification Requests
      </strong>
    </div>
    <tm-account-verification-request-table>
      <div
        class="table-responsive"
      >
        <table
          class="table table-striped"
          id="search-table-account-verification-request"
        >
          <thead>
            <tr>
              <th
                class="text-nowrap"
              >
                Name
              </th>
              <th
                class="text-nowrap"
              >
                Email
              </th>
              <th
                class="text-nowrap"
              >
                Status
              </th>
              <th
                class="text-nowrap"
              >
                Institute
              </th>
              <th
                class="text-nowrap"
              >
                Country
              </th>
              <th
                class="text-nowrap"
              >
                Submitted At
              </th>
              <th
                class="text-nowrap"
              >
                Comments
              </th>
              <th
                class="text-nowrap"
              >
                Options
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td
                class="text-center"
                colspan="8"
              >
                No pending account verification requests
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </tm-account-verification-request-table>
  </div>
</tm-admin-home-page>
`;
