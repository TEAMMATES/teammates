              for="template-selector"
            >
              <strong>
                Select Template to Edit
              </strong>
            </label>
            <select
              class="form-control ng-untouched ng-pristine ng-valid"
              id="template-selector"
            >
              <option
                value="NEW_INSTRUCTOR_ACCOUNT_WELCOME"
              >
                NEW_INSTRUCTOR_ACCOUNT_WELCOME
              </option>
            </select>
          </div>
        </div>
      </div>
      <div
        class="card margin-top-20px"
      >
        <div
