exports[`AdminEmailTemplatesPageComponent should snap when template body is loading 1`] = `
<tm-admin-email-templates-page
  emailTemplateService={[Function EmailTemplateService]}
  hasKeysLoadingFailed="false"
  isKeysLoading="false"
  isReverting="false"
