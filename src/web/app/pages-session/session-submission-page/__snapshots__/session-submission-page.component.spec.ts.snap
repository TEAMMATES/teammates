  loggedInUser={[Function String]}
  moderatedPerson=""
  moderatedQuestionId=""
  navigationService={[Function _NavigationService]}
  ngbModal={[Function NgbModal]}
  pageScrollService={[Function _PageScrollService]}
  personEmail={[Function String]}
  personName={[Function String]}
  previewAsPerson=""
  questionSubmissionForms={[Function Array]}
  recipientQuestionMap={[Function Map]}
  regKey={[Function String]}
  retryAttempts={[Function Number]}
  route={[Function Object]}
  simpleModalService={[Function _SimpleModalService]}
  statusMessageService={[Function _StatusMessageService]}
  studentService={[Function _StudentService]}
  submissionReceiptService={[Function _SubmissionReceiptService]}
  timezoneService={[Function _TimezoneService]}
  ungroupableQuestionsSorted={[Function Array]}
>
  <div
    class="row"
  >
    <div
      class="col-12"
    >
      <div
        class="alert alert-primary"
        role="alert"
      >
        <div>
           You are submitting feedback as 
          <mark>
            <b>
              person name
            </b>
          </mark>
          . If you wish to link your Google account (logged-in-user) with this user, 
          <a
            href="#"
          >
            click here
          </a>
          . 
        </div>
      </div>
    </div>
  </div><div
    class="alert alert-primary"
    role="alert"
  >
    <i
      class="fas fa-info-circle"
    />
     You may edit and resubmit your responses any number of times before the session closes. 
  </div><div
    class="card border bg-body-tertiary mb-3"
  >
    <div
      class="card-body"
    >
      <div
        class="flex-grow-1"
      >
        <h2
          class="fs-4 fw-semibold mb-2"
          id="fs-name"
        >
          First team feedback session
        </h2>
        <div
          class="text-secondary d-flex flex-wrap gap-3"
        >
          <span>
            <strong>
              Opening:
            </strong>
             Sun, 01 Apr, 2012, 11:59 PM +08
          </span>
          <span>
            <strong>
              Closing:
            </strong>
             Mon, 02 Apr, 2012, 11:59 PM +08
          </span>
        </div>
        <div
          class="mt-3"
        >
          <div
            class="text-secondary mb-1"
          >
            <strong>
              Instructions
            </strong>
          </div>
          <div
            class="lh-base"
            id="instructions"
          >
            Please give your feedback based on the following questions.
          </div>
        </div>
        <details
          class="d-inline-block mt-3"
        >
          <summary
            class="text-secondary"
          >
            Session details
          </summary>
          <div
            class="d-flex flex-column gap-2 text-secondary mt-2"
          >
            <div>
              <strong>
                Course:
              </strong>
               Course name
            </div>
            <div>
              <strong>
                Institute:
              </strong>
               Test institute
            </div>
          </div>
        </details>
      </div>
    </div>
  </div><div
    class="border rounded bg-body mb-3 px-3 py-3"
  >
    <div
      class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2"
    >
      <div
        class="d-flex flex-column gap-1"
      >
        <div
          class="fw-semibold"
        >
          Submission status
        </div>
        <div
          class="d-flex flex-wrap align-items-center gap-2"
        >
          <span
            class="text-secondary"
          >
            0 questions
          </span>
        </div>
      </div>
      <div
        class="d-inline-flex align-items-center gap-2 flex-nowrap"
      >
        <label
          class="form-label mb-0 text-secondary text-nowrap"
          for="select-group-by"
        >
          Group by
        </label>
        <select
          aria-label="Select group by view"
          class="form-control form-select w-auto group-by-select"
          id="select-group-by"
        >
          <option
            value="Question"
          >
             Question 
          </option>
          <option
            value="Recipient"
          >
             Recipient 
          </option>
        </select>
      </div>
    </div>
  </div><tm-loading-retry>
    <div
      aria-hidden="true"
    />
    <tm-loading-spinner>
      <div
        class="loading-container"
      >
        <div
          class="row spinner-border text-primary"
          role="status"
        />
        <div
          class="row text-secondary"
        >
          Loading...
        </div>
      </div>
    </tm-loading-spinner>
  </tm-loading-retry>
</tm-session-submission-page>
`;

