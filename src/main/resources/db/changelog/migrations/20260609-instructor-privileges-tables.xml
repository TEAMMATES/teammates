    <changeSet author="samuelfangjw" id="20260609-instructor-privileges-tables-2">
        <dropColumn columnName="privileges" tableName="instructors"/>

        <rollback>
            <addColumn tableName="instructors">
                <column name="privileges" type="TEXT">
                    <constraints nullable="false"/>
                </column>
            </addColumn>
        </rollback>
