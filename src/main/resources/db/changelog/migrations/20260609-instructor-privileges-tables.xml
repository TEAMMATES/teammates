            tableName="instructor_course_privileges"/>

        <addForeignKeyConstraint baseColumnNames="instructor_id"
            baseTableName="instructor_course_privileges"
            constraintName="FK_instructor_course_privileges_instructor_id"
            deferrable="false"
            initiallyDeferred="false"
            onDelete="CASCADE"
            referencedColumnNames="id"
            referencedTableName="instructors"
            validate="true"/>

